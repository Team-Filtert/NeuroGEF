; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="NeuroGEF"
run/main_scene="uid://e8g71q3f1nju"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://c3jlhdod1mgrj"

[audio]

buses/default_bus_layout="res://resources/default_bus_layout.tres"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"
PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"
AudioManager="*res://autoloads/audio_manager.gd"
CameraManager="*res://autoloads/camera_manager.gd"
CombatManager="*res://autoloads/combat_manager.gd"
CutsceneManager="*res://autoloads/cutscene_manager.gd"
InventoryManager="*res://autoloads/inventory_manager.gd"
LevelUpManager="*res://autoloads/level_up_manager.gd"
LoadManager="*res://autoloads/load_manager.gd"
PartyManager="*res://autoloads/party_manager.gd"
SaveManager="*res://autoloads/save_manager.gd"
SceneManager="*res://autoloads/scene_manager.gd"
Game="*res://autoloads/game.gd"
LevelManager="*res://autoloads/level_manager.gd"
PlayerManager="*res://autoloads/player_manager.gd"

[dialogic]

directories/dch_directory={
"iceboi45": "res://characters/iceboi45.dch",
"neuro": "res://characters/neuro.dch",
"swarmduty669": "res://characters/swarmduty669.dch"
}
directories/dtl_directory={
"combat_demo_1_timeline": "res://dialogue/combat_demo_1_timeline.dtl",
"combat_demo_2_timeline": "res://dialogue/combat_demo_2_timeline.dtl",
"combat_demo_3_timeline": "res://dialogue/combat_demo_3_timeline.dtl",
"swarm_wakes_neuro_up": "res://dialogue/swarm_wakes_neuro_up.dtl",
"test_timeline": "res://dialogue/test_timeline.dtl"
}
layout/style_directory={}
layout/style_list=[]
layout/default_style="res://assets/dialogue/theme_default.tres"
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
variables={
"CombatDemo": {
"NextDemoNum": 0
}
}
glossary/default_case_sensitive=true

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[editor]

movie_writer/movie_file="/home/dedus/jrpg-combat/render.avi"
movie_writer/fps=30

[editor_plugins]

enabled=PackedStringArray("res://addons/TileMapDual/plugin.cfg", "res://addons/dialogic/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

